# ============================================================
#  FOTOS JACKY — .gitignore
#  Lo que NUNCA debe subirse al repositorio
# ============================================================

# --- Secretos y variables de entorno (¡CRÍTICO!) ---
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# --- Dependencias (se reinstalan, no se versionan) ---
node_modules/
backend/venv/
venv/
__pycache__/
*.py[cod]

# --- Builds y artefactos ---
dist/
build/
*.log

# --- Sistema operativo ---
.DS_Store
Thumbs.db

# --- Editores ---
.vscode/
.idea/
*.swp

# --- Misc ---
*.tmp
.cache/
