# =============================================================================
# Fotos Jacky Backend — Variables de Entorno
# Copiar este archivo como .env y completar con tus valores reales
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Encontrar en: Supabase Dashboard → Settings → API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJ...tu_anon_key_aqui
SUPABASE_SERVICE_KEY=eyJ...tu_service_role_key_aqui

# --- JWT (Admin Panel) -------------------------------------------------------
# Generar un string aleatorio largo para firmar los tokens del panel admin
# Ejemplo: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIAR_POR_UN_SECRET_ALEATORIO_LARGO
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# --- Admin Credentials -------------------------------------------------------
# Usuario y contraseña para el panel de administración
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIAR_POR_UNA_CONTRASEÑA_SEGURA

# --- App Config --------------------------------------------------------------
APP_NAME=Fotos Jacky
APP_ENV=development
FRONTEND_URL=http://localhost:5500
CORS_ORIGINS=http://localhost:5500,http://localhost:3000

# --- Storage -----------------------------------------------------------------
# Nombre del bucket en Supabase Storage para imágenes de productos
STORAGE_BUCKET=product-images
